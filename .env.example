# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/yourdb?appName=Cluster0

# Google Maps Geocoding + Directions + Places (for address autocomplete)
# Enable Places API in Google Cloud Console for address suggestions
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Cloud Project (for Fleet Routing optimizeTours)
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id

# Service account JSON stringified (for OAuth token to call optimizeTours)
# Get from Google Cloud Console → IAM → Service Accounts → Create key (JSON)
# Paste the full JSON object as a single line. Must start with { (no extra outer quotes).
# Example format: {"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SERVICE_ACCOUNT_JSON=paste_your_service_account_json_here

# OpenPhone/Quo (SMS for ETA notifications)
# API key: Quo app → Workspace Settings → API tab → Generate API key
# US carrier registration required to send SMS to US numbers
OPENPHONE_API_KEY=your_openphone_api_key
# E.164 format (e.g. +14165551234) — must be an OpenPhone number you own
OPENPHONE_FROM=+1XXXXXXXXXX

# Driver link security (long random string for HMAC)
DRIVER_LINK_SECRET=your_long_random_secret_string

# Admin login (run: node scripts/hash-admin-password.js "yourPassword")
ADMIN_PASSWORD_HASH=salt:hexhash
# Long random string for signing admin session cookies
ADMIN_SESSION_SECRET=your_long_random_secret

# Cloudflare R2 (optional - for proof-of-delivery photos)
# If set, photos upload to R2 instead of local disk. Required for Vercel/production.
# Get from Cloudflare Dashboard → R2 → bucket Settings → Public Development URL
# For direct browser uploads: add CORS rule on bucket allowing your domain (e.g. https://delivery.kapioo.com)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=kapioo-proof-photos
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Kapioo Admin POD ingestion (optional - for syncing delivery completion to Kapioo Admin)
# When unset, completion still succeeds locally and stop.kapioo_sync is recorded as
# failed with reason "missing-env" so admin can retry from run-details after env is set.
# Base URL of the Kapioo Admin/customer system (no trailing slash needed)
KAPIOO_ADMIN_BASE_URL=https://admin.kapioo.com
# Bearer token shared with Kapioo Admin's ingestion endpoint (long random string)
ROUTE_OPTIMIZER_INGEST_TOKEN=your_long_random_ingest_token
# HMAC-SHA256 shared secret for signing the request body (X-RO-Signature header)
ROUTE_OPTIMIZER_INGEST_SECRET=your_long_random_ingest_secret
